# Server Environment Variables (Production Template)

# PostgreSQL Database Connection String
# Format: postgres://username:password@host:port/database?schema=public
DATABASE_URL="postgres://user:password@localhost:5432/compupay?schema=public"

# Redis Connection String (for BullMQ Workers)
# Format: redis://:password@host:port
REDIS_URL="redis://localhost:6379"

# JWT Secret for signing tokens
# CRITICAL: Use a strong, long random string in production (e.g. `openssl rand -base64 32`)
JWT_SECRET="replace-with-secure-random-string"

# Port to listen on (Default: 3000)
PORT=3000

# Node Environment (development/production)
NODE_ENV="production"
