{
    "name": "compu-pay-monorepo",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "concurrently \"pnpm --filter server dev\" \"pnpm --filter compu-pay dev\" -c \"blue,magenta\" --names \"SERVER,CLIENT\"",
        "build": "pnpm -r build",
        "test": "pnpm -r test",
        "lint": "pnpm -r lint",
        "clean": "pnpm -r exec -- rm -rf node_modules dist .next"
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    },
    "engines": {
        "node": ">=18"
    }
}